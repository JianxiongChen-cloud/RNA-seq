
---

# .gitignore

```gitignore
#################################################
# Raw sequencing data
#################################################
*.fastq.gz
*.fq.gz
*.fastq
*.fq

#################################################
# Alignment files
#################################################
*.bam
*.bai
*.sam

#################################################
# Temporary / large output folders
#################################################
align/
qc/
reference/star_index/

#################################################
# R session files
#################################################
.Rhistory
.RData
.Rproj.user/

#################################################
# Logs
#################################################
*.log
*.out
*.err

#################################################
# OS / editor files
#################################################
.DS_Store
Thumbs.db
.vscode/
.idea/

#################################################
# Python / Conda cache
#################################################
__pycache__/
*.pyc
.conda/
.env

#################################################
# Figures generated repeatedly (optional)
#################################################
*.tmp
